# Copiar a .env y completar los valores
# NUNCA subir .env al repositorio

# Seguridad JWT
SECRET_KEY=cambia-esto-por-una-clave-secreta-muy-larga-y-aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Base de datos
DATABASE_URL=sqlite:///./backend/taller.db

# Aplicación
APP_NAME=Taller LatonPaint
APP_VERSION=1.0.0
DEBUG=false

# CORS (dominios permitidos, separados por coma)
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
